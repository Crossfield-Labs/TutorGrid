{
  "name": "tutorgrid-desktop",
  "version": "0.0.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --mode dev",
    "build": "vite build --mode pro",
    "electron:compile": "tsc -p tsconfig.electron.json",
    "electron:dev": "concurrently -k \"yarn dev\" \"yarn electron:compile --watch\" \"wait-on http://localhost:4399/index.html dist-electron/main.js && cross-env VITE_DEV_SERVER_URL=http://localhost:4399 electron dist-electron/main.js\"",
    "electron:build": "yarn build && yarn electron:compile && electron-builder",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage"
  },
  "build": {
    "appId": "cn.concreteai.tutorgrid",
    "productName": "TutorGrid",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "icon": "build/icons/app-icon.ico",
      "target": "nsis"
    },
    "nsis": {
      "installerIcon": "build/icons/app-icon.ico",
      "uninstallerIcon": "build/icons/app-icon.ico"
    }
  },
  "dependencies": {
    "@formkit/auto-animate": "^0.7.0",
    "@mdi/font": "7.2.96",
    "@tiptap/extension-highlight": "2.0.2",
    "@tiptap/extension-image": "2.0.2",
    "@tiptap/pm": "^2.0.2",
    "@tiptap/starter-kit": "^2.0.2",
    "@tiptap/vue-3": "^2.0.2",
    "@vueuse/core": "^9.13.0",
    "@vueuse/integrations": "^9.13.0",
    "@yeger/vue-masonry-wall": "^3.4.4",
    "axios": "^1.3.5",
    "clipboard": "^2.0.11",
    "dompurify": "^3.4.2",
    "echarts": "^5.4.2",
    "grid-layout-plus": "^1.1.1",
    "gsap": "^3.15.0",
    "happy-dom": "^9.6.1",
    "marked": "^18.0.2",
    "pinia": "^2.0.34",
    "pinia-plugin-persist": "^1.0.0",
    "plantuml-encoder": "^1.4.0",
    "roboto-fontface": "*",
    "vue": "^3.2.47",
    "vue-echarts": "^6.5.4",
    "vue-i18n": "^9.2.2",
    "vue-router": "^4.1.6",
    "vue-virtual-scroller": "^2.0.0-beta.8",
    "vue3-perfect-scrollbar": "^1.6.1",
    "vuedraggable": "^4.1.0",
    "vuetify": "^3.3.6"
  },
  "devDependencies": {
    "@iconify/vue": "^4.1.1",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^18.15.11",
    "@vitejs/plugin-vue": "^4.1.0",
    "@vitest/ui": "^0.30.1",
    "@vue/test-utils": "^2.0.0-rc.18",
    "autoprefixer": "^10.4.14",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.21",
    "sass": "^1.61.0",
    "typescript": "^6.0.3",
    "unplugin-auto-import": "^0.15.2",
    "vite": "^4.3.2",
    "vite-plugin-vuetify": "^1.0.2",
    "vitest": "^0.30.1",
    "wait-on": "^9.0.5"
  }
}
